@page
@{
    ViewData["Title"] = "Brak dostępu";
}

<div class="identity-page">
    <div class="identity-card shadow-lg">
        <div class="identity-header">
            <h1>Brak dostępu</h1>
            <p>Ta sekcja jest dostępna tylko dla użytkowników z odpowiednimi uprawnieniami.</p>
        </div>

        <div class="alert alert-light border mb-4">
            Jeśli sądzisz, że to błąd, zaloguj się na właściwe konto albo skontaktuj się z administratorem.
        </div>

        <div class="identity-links">
            <a asp-area="" asp-controller="Home" asp-action="Index">Wróć na stronę główną</a>
            <a asp-page="./Login">Przejdź do logowania</a>
        </div>
    </div>
</div>
