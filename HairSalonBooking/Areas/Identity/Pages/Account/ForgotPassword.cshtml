@page
@model ForgotPasswordModel

@{
    ViewData["Title"] = "Reset hasła";
}

<div class="identity-page">
    <div class="identity-card shadow-lg">
        <div class="identity-header">
            <h1>Reset hasła</h1>
            <p>Podaj adres e-mail, aby otrzymać instrukcję resetowania hasła.</p>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-4">
                <label asp-for="Input.Email" class="form-label">Adres e-mail</label>
                <input asp-for="Input.Email" class="form-control identity-input" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 identity-btn">
                Wyślij link resetujący
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}