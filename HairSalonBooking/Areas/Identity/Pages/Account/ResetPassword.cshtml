@page
@model ResetPasswordModel

@{
    ViewData["Title"] = "Ustaw nowe hasło";
}

<div class="identity-page">
    <div class="identity-card shadow-lg">
        <div class="identity-header">
            <h1>Ustaw nowe hasło</h1>
            <p>Wpisz adres e-mail i nowe hasło, aby zakończyć reset.</p>
        </div>

        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input asp-for="Input.Code" type="hidden" />

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Adres e-mail</label>
                <input asp-for="Input.Email" class="form-control identity-input" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label">Nowe hasło</label>
                <input asp-for="Input.Password" class="form-control identity-input" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Input.ConfirmPassword" class="form-label">Potwierdź nowe hasło</label>
                <input asp-for="Input.ConfirmPassword" class="form-control identity-input" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 identity-btn">
                Zapisz nowe hasło
            </button>

            <div class="identity-links mt-4">
                <a asp-page="./Login">Wróć do logowania</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
