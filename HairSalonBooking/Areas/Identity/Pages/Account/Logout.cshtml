@page
@model LogoutModel
@{
    ViewData["Title"] = "Wylogowanie";
}

<div class="identity-page">
    <div class="identity-card shadow-lg">
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <div class="identity-header">
                <h1>Wylogowanie</h1>
                <p>Kończysz bieżącą sesję w HairSalonBooking.</p>
            </div>

            <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                <button type="submit" class="btn btn-primary w-100 identity-btn">
                    Wyloguj mnie
                </button>
            </form>

            <div class="identity-links mt-4">
                <a asp-area="" asp-controller="Home" asp-action="Index">Wróć na stronę główną</a>
            </div>
        }
        else
        {
            <div class="identity-header">
                <h1>Sesja zakończona</h1>
                <p>Zostałaś lub zostałeś poprawnie wylogowany z aplikacji.</p>
            </div>

            <div class="identity-links">
                <a asp-page="./Login">Zaloguj się ponownie</a>
                <a asp-area="" asp-controller="Home" asp-action="Index">Przejdź na stronę główną</a>
            </div>
        }
    </div>
</div>
