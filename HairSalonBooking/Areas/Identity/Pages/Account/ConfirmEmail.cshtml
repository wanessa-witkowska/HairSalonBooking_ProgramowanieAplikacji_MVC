@page
@model ConfirmEmailModel
@{
    ViewData["Title"] = "Potwierdzenie adresu e-mail";
}

<div class="identity-page">
    <div class="identity-card shadow-lg">
        <div class="identity-header">
            <h1>Potwierdzenie adresu e-mail</h1>
            <p>@Model.StatusMessage</p>
        </div>

        @if (Model.IsSuccess)
        {
            <div class="alert alert-success mb-4">
                Adres e-mail został potwierdzony. Możesz korzystać ze wszystkich funkcji konta.
            </div>
        }
        else
        {
            <div class="alert alert-danger mb-4">
                Nie udało się potwierdzić adresu e-mail. Sprawdź, czy używasz pełnego i aktualnego linku z wiadomości.
            </div>
        }

        <div class="identity-links">
            <a asp-page="./Login">Przejdź do logowania</a>
            <a asp-area="" asp-controller="Home" asp-action="Index">Wróć na stronę główną</a>
        </div>
    </div>
</div>
