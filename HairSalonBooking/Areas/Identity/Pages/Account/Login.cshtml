@page
@model LoginModel

@{
    ViewData["Title"] = "Logowanie";
}

<div class="identity-page">
    <div class="identity-card shadow-lg">
        <div class="identity-header">
            <h1>Logowanie</h1>
            <p>Zaloguj się do swojego konta i zarządzaj rezerwacjami.</p>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Adres e-mail</label>
                <input asp-for="Input.Email" class="form-control identity-input" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label">Hasło</label>
                <input asp-for="Input.Password" class="form-control identity-input" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input class="form-check-input" asp-for="Input.RememberMe" />
                <label class="form-check-label" asp-for="Input.RememberMe">Zapamiętaj mnie</label>
            </div>

            <button id="login-submit" type="submit" class="btn btn-primary w-100 identity-btn">
                Zaloguj się
            </button>

            <div class="identity-links mt-4">
                <a asp-page="./ForgotPassword">Nie pamiętasz hasła?</a>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Nie masz konta? Zarejestruj się</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}