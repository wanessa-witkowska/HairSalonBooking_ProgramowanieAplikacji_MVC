@page
@{
    ViewData["Title"] = "Wiadomość została wysłana";
}

<div class="identity-page">
    <div class="identity-card shadow-lg">
        <div class="identity-header">
            <h1>Sprawdź skrzynkę mailową</h1>
            <p>Jeśli podany adres istnieje w systemie, wysłaliśmy wiadomość z linkiem do ustawienia nowego hasła.</p>
        </div>

        <div class="alert alert-light border mb-4">
            <strong>Tryb deweloperski:</strong> jeśli SMTP nie jest skonfigurowane, wiadomość trafi do lokalnego folderu
            <code>output/emails</code>.
        </div>

        <div class="identity-links">
            <a asp-page="./Login">Wróć do logowania</a>
            <a asp-page="./ForgotPassword">Wyślij link ponownie</a>
        </div>
    </div>
</div>
