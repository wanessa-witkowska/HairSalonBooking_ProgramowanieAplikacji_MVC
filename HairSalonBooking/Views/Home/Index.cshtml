@{
    ViewData["Title"] = "Strona główna";
}

<section class="hero-section hero-full">
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <span class="hero-badge">Salon fryzjerski online</span>
                <h1 class="display-4 fw-bold mt-3">Umów wizytę szybko i wygodnie</h1>
                <p class="lead mt-3">
                    Przeglądaj usługi, wybierz dogodny termin i zarządzaj swoimi rezerwacjami w jednym miejscu.
                </p>
                <div class="d-flex gap-3 mt-4">
                    <a asp-controller="Services" asp-action="Index" class="btn btn-primary btn-lg">Zobacz usługi</a>
                    <a asp-controller="Reservations" asp-action="Calendar" class="btn btn-outline-light btn-lg">Kalendarz</a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hero-card shadow-lg">
                    <h3>Dlaczego warto?</h3>
                    <ul class="mt-3 mb-0">
                        <li>prosty system rezerwacji online</li>
                        <li>panel administratora</li>
                        <li>powiadomienia mailowe</li>
                        <li>filtrowanie i wyszukiwarka usług</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>