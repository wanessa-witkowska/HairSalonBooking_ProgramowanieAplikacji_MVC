@model HairSalonBooking.ViewModels.ReservationCreateViewModel

@{
    ViewData["Title"] = "Nowa rezerwacja";
}

<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <h1 class="mb-3">Rezerwacja usługi</h1>

            <p><strong>Usługa:</strong> @Model.ServiceName</p>
            <p><strong>Cena:</strong> @Model.Price.ToString("0.00") zł</p>
            <p><strong>Czas:</strong> @Model.DurationMinutes min</p>

            <form asp-action="Create" method="post">
                <input asp-for="ServiceId" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="AvailableSlotId" class="form-label"></label>
                    <select asp-for="AvailableSlotId" asp-items="Model.SlotOptions" class="form-select">
                        <option value="">-- wybierz termin --</option>
                    </select>
                    <span asp-validation-for="AvailableSlotId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Notes" class="form-label"></label>
                    <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-success">Zarezerwuj</button>
                <a asp-controller="Services" asp-action="Details" asp-route-id="@Model.ServiceId" class="btn btn-outline-secondary">Powrót</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}