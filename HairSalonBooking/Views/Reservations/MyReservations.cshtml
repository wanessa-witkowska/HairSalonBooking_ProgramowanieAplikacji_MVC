@model IEnumerable<HairSalonBooking.Models.Reservation>

@{
    ViewData["Title"] = "Moje rezerwacje";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Moje rezerwacje</h1>
        <a asp-action="Calendar" class="btn btn-outline-primary">Kalendarz</a>
    </div>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }

    <form method="get" class="row g-3 mb-4">
        <div class="col-md-4">
            <select name="status" class="form-select" data-auto-submit="true">
                <option value="">Wszystkie statusy</option>
                @foreach (var status in Enum.GetValues(typeof(HairSalonBooking.Models.ReservationStatus)))
                {
                    <option value="@status" selected="@(ViewBag.Status?.ToString() == status!.ToString())">@status</option>
                }
            </select>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Usługa</th>
                    <th>Data</th>
                    <th>Status</th>
                    <th>Uwagi</th>
                    <th>Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Service.Name</td>
                        <td>@item.ReservationDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td><partial name="_ReservationStatusBadge" model="item.Status" /></td>
                        <td>@item.Notes</td>
                        <td class="actions-cell">
                            <div class="actions-wrap">
                                @if (item.Status == HairSalonBooking.Models.ReservationStatus.Pending)
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edytuj</a>
                                }

                                @if (item.Status != HairSalonBooking.Models.ReservationStatus.Cancelled && item.Status != HairSalonBooking.Models.ReservationStatus.Rejected)
                                {
                                    <form asp-action="Cancel" method="post" class="d-inline" data-confirm="Czy na pewno chcesz anulować rezerwację?">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Anuluj</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>