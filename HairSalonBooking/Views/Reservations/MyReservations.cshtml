@model IEnumerable<HairSalonBooking.Models.Reservation>

@{
    ViewData["Title"] = "Moje rezerwacje";
}

<div class="container py-4">
    <h1 class="mb-4">Moje rezerwacje</h1>

    @if (TempData["Success"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Usługa</th>
                    <th>Data</th>
                    <th>Status</th>
                    <th>Uwagi</th>
                    <th>Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Service.Name</td>
                        <td>@item.ReservationDate.ToString("dd.MM.yyyy HH:mm")</td>
                        <td>@item.Status</td>
                        <td>@item.Notes</td>
                        <td class="d-flex gap-2">
                            @if (item.Status == HairSalonBooking.Models.ReservationStatus.Pending)
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edytuj</a>
                            }

                            @if (item.Status != HairSalonBooking.Models.ReservationStatus.Cancelled && item.Status != HairSalonBooking.Models.ReservationStatus.Rejected)
                            {
                                <form asp-action="Cancel" method="post" class="d-inline" data-confirm="Czy na pewno chcesz anulować rezerwację?">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Anuluj</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>