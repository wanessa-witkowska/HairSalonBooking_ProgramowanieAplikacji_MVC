@model IEnumerable<HairSalonBooking.Models.Service>

@{
    ViewData["Title"] = "Usługi";
}

<div class="container py-4">
    <h1 class="mb-4">Nasze usługi</h1>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm service-card">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@item.Name</h5>
                        <p class="text-muted">@item.Category</p>
                        <p class="card-text flex-grow-1">@item.Description</p>
                        <p class="mb-1"><strong>Cena:</strong> @item.Price.ToString("0.00") zł</p>
                        <p><strong>Czas:</strong> @item.DurationMinutes min</p>
                        <a asp-controller="Services" asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary mt-auto">Szczegóły</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>