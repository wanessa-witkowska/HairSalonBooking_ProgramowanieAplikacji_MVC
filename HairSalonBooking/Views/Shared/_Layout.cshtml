@using Microsoft.AspNetCore.Identity
@using HairSalonBooking.Models
@inject SignInManager<AppUser> SignInManager
@{
    var bodyClass = Context.Request.Path.StartsWithSegments("/Identity/Account/Manage")
        ? "identity-manage-shell"
        : string.Empty;
}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HairSalonBooking</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="@bodyClass">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark salon-navbar">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">HairSalonBooking</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Start</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Services" asp-action="Index">Usługi</a>
                        </li>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Reservations" asp-action="MyReservations">Moje rezerwacje</a>
                            </li>
                        }

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Panel admina</a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="AdminDashboard" asp-action="Index">Dashboard</a></li>
                                    <li><a class="dropdown-item" asp-controller="AdminServices" asp-action="Index">Usługi</a></li>
                                    <li><a class="dropdown-item" asp-controller="AdminSlots" asp-action="Index">Terminy</a></li>
                                    <li><a class="dropdown-item" asp-controller="AdminReservations" asp-action="Index">Rezerwacje</a></li>
                                </ul>
                            </li>
                        }
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="salon-footer">
        <div class="container py-4">
            <p class="mb-0">HairSalonBooking - Wanessa Witkowska</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
