@using Microsoft.AspNetCore.Identity
@using HairSalonBooking.Models
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager
@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString();
}

<ul class="navbar-nav salon-auth-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        var userName = UserManager.GetUserName(User) ?? "Konto";
        var userInitial = string.IsNullOrWhiteSpace(userName) ? "K" : userName.Substring(0, 1).ToUpperInvariant();

        <li class="nav-item">
            <a class="nav-link salon-auth-link @(currentPage?.StartsWith("/Account/Manage") == true ? "active" : string.Empty)" asp-area="Identity" asp-page="/Account/Manage/Index">
                <span class="salon-auth-avatar">@userInitial</span>
                <span>@userName</span>
            </a>
        </li>
        <li class="nav-item">
            <form class="salon-auth-form" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home")">
                <button type="submit" class="nav-link btn btn-link salon-auth-link">Wyloguj</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link salon-auth-link @(currentPage == "/Account/Register" ? "active" : string.Empty)" asp-area="Identity" asp-page="/Account/Register">Rejestracja</a>
        </li>
        <li class="nav-item">
            <a class="nav-link salon-auth-button @(currentPage == "/Account/Login" ? "active" : string.Empty)" asp-area="Identity" asp-page="/Account/Login">Logowanie</a>
        </li>
    }
</ul>
