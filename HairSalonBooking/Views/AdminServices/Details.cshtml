@model HairSalonBooking.Models.Service

@{
    ViewData["Title"] = "Szczegóły usługi";
}

<div class="container py-4 admin-page">
    <div class="admin-form-wrapper">
        <div class="card admin-card shadow-sm">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h1>Szczegóły usługi</h1>
                    <p class="text-muted mb-0">Podgląd informacji o wybranej usłudze.</p>
                </div>

                <div class="admin-details-grid">
                    <div class="admin-detail-item">
                        <span class="admin-detail-label">Nazwa usługi</span>
                        <span class="admin-detail-value">@Model.Name</span>
                    </div>

                    <div class="admin-detail-item">
                        <span class="admin-detail-label">Cena</span>
                        <span class="admin-detail-value">@Model.Price.ToString("0.00") zł</span>
                    </div>

                    <div class="admin-detail-item">
                        <span class="admin-detail-label">Czas trwania</span>
                        <span class="admin-detail-value">@Model.DurationMinutes min</span>
                    </div>

                    <div class="admin-detail-item">
                        <span class="admin-detail-label">Kategoria</span>
                        <span class="admin-detail-value">@Model.Category</span>
                    </div>

                    <div class="admin-detail-item" style="grid-column: 1 / -1;">
                        <span class="admin-detail-label">Opis</span>
                        <span class="admin-detail-value">@Model.Description</span>
                    </div>

                    <div class="admin-detail-item">
                        <span class="admin-detail-label">Status</span>
                        <span class="admin-detail-value">
                            @if (Model.IsActive)
                            {
                                <span class="badge rounded-pill bg-success">Aktywna</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-secondary">Nieaktywna</span>
                            }
                        </span>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary admin-action-btn">Edytuj</a>
                    <a asp-action="Index" class="btn btn-outline-secondary">Powrót</a>
                </div>
            </div>
        </div>
    </div>
</div>