@model IEnumerable<HairSalonBooking.Models.Service>

@{
    ViewData["Title"] = "Zarządzanie usługami";
}

<div class="container py-4 admin-page">
    <div class="admin-header mb-4">
        <div>
            <h1>Zarządzanie usługami</h1>
            <p>Dodawaj, edytuj i usuwaj usługi dostępne w salonie.</p>
        </div>

        <a asp-action="Create" class="btn btn-primary admin-action-btn">Dodaj usługę</a>
    </div>

    <div class="card admin-card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table admin-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Nazwa usługi</th>
                            <th>Opis</th>
                            <th>Cena</th>
                            <th>Czas trwania</th>
                            <th>Kategoria</th>
                            <th>Status</th>
                            <th class="text-end">Akcje</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td>@item.Description</td>
                                <td>@item.Price.ToString("0.00") zł</td>
                                <td>@item.DurationMinutes min</td>
                                <td>@item.Category</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge rounded-pill bg-success">Aktywna</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-secondary">Nieaktywna</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex justify-content-end gap-2 flex-wrap">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edytuj</a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Szczegóły</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Usuń</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>