@model HairSalonBooking.Models.Service

@{
    ViewData["Title"] = "Edytuj usługę";
}

<div class="container py-4 admin-page">
    <div class="admin-form-wrapper">
        <div class="card admin-card shadow-sm">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h1>Edytuj usługę</h1>
                    <p class="text-muted mb-0">Zaktualizuj dane wybranej usługi.</p>
                </div>

                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Nazwa usługi</label>
                        <input asp-for="Name" class="form-control admin-input" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">Opis</label>
                        <textarea asp-for="Description" class="form-control admin-input" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Price" class="form-label">Cena</label>
                        <input asp-for="Price" class="form-control admin-input" type="number" step="0.01" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DurationMinutes" class="form-label">Czas trwania (min)</label>
                        <input asp-for="DurationMinutes" class="form-control admin-input" type="number" />
                        <span asp-validation-for="DurationMinutes" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Category" class="form-label">Kategoria</label>
                        <input asp-for="Category" class="form-control admin-input" />
                        <span asp-validation-for="Category" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input class="form-check-input" asp-for="IsActive" />
                        <label class="form-check-label" asp-for="IsActive">Usługa aktywna</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary admin-action-btn">Zapisz zmiany</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Powrót</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}