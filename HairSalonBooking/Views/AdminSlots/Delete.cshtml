@model HairSalonBooking.Models.AvailableSlot

@{
    ViewData["Title"] = "Szczegóły terminu";
}

<div class="container py-4 admin-page">
    <div class="admin-form-wrapper">
        <div class="card admin-card shadow-sm">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h1>Szczegóły terminu</h1>
                    <p class="text-muted mb-0">Podgląd informacji o wybranym terminie.</p>
                </div>

                <div class="admin-details-grid">
                    <div class="admin-detail-item">
                        <span class="admin-detail-label">Początek</span>
                        <span class="admin-detail-value">@Model.StartTime.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>

                    <div class="admin-detail-item">
                        <span class="admin-detail-label">Koniec</span>
                        <span class="admin-detail-value">@Model.EndTime.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>

                    <div class="admin-detail-item">
                        <span class="admin-detail-label">Status</span>
                        <span class="admin-detail-value">
                            @if (Model.IsBooked)
                            {
                                <span class="badge rounded-pill bg-danger">Zajęty</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-success">Wolny</span>
                            }
                        </span>
                    </div>

                    <div class="admin-detail-item">
                        <span class="admin-detail-label">Usługa</span>
                        <span class="admin-detail-value">@Model.Service?.Name</span>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary admin-action-btn">Edytuj</a>
                    <a asp-action="Index" class="btn btn-outline-secondary">Powrót</a>
                </div>
            </div>
        </div>
    </div>
</div>