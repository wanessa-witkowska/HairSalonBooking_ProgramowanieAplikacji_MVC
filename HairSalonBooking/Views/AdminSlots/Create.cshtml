@model HairSalonBooking.Models.AvailableSlot

@{
    ViewData["Title"] = "Dodaj termin";
}

<div class="container py-4 admin-page">
    <div class="admin-form-wrapper">
        <div class="card admin-card shadow-sm">
            <div class="card-body p-4">
                <div class="mb-4">
                    <h1>Dodaj termin</h1>
                    <p class="text-muted mb-0">Utwórz nowy dostępny termin dla wybranej usługi.</p>
                </div>

                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="StartTime" class="form-label">Początek</label>
                        <input asp-for="StartTime" class="form-control admin-input" type="datetime-local" />
                        <span asp-validation-for="StartTime" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="EndTime" class="form-label">Koniec</label>
                        <input asp-for="EndTime" class="form-control admin-input" type="datetime-local" />
                        <span asp-validation-for="EndTime" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ServiceId" class="form-label">Usługa</label>
                        <select asp-for="ServiceId" class="form-select admin-input" asp-items="ViewBag.ServiceId"></select>
                        <span asp-validation-for="ServiceId" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-4">
                        <input class="form-check-input" asp-for="IsBooked" />
                        <label class="form-check-label" asp-for="IsBooked">Termin zajęty</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary admin-action-btn">Zapisz</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Powrót</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}